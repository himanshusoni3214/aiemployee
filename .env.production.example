APP_HOST=ops.themealz.com
TRAEFIK_NETWORK=hermes-agent-yepj_default
TRAEFIK_CERT_RESOLVER=letsencrypt

POSTGRES_DB=voryx_ops
POSTGRES_USER=voryx
POSTGRES_PASSWORD=replace-with-strong-database-password
DATABASE_URL=postgresql+psycopg://voryx:replace-with-strong-database-password@db:5432/voryx_ops

REDIS_URL=redis://redis:6379/0

JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FIRST_SUPERUSER_EMAIL=admin@themealz.com
FIRST_SUPERUSER_PASSWORD=replace-with-temporary-admin-password
CREDENTIAL_ENCRYPTION_KEY=replace-with-fernet-key

# Existing Hostinger Hermes Agent discovered on the VPS.
# This endpoint currently exposes ttyd/Hermes gateway monitoring; job submission path is still unverified.
HERMES_BASE_URL=http://hermes-agent:4860
HERMES_JOBS_PATH=/jobs
HERMES_DATA_PATH=/hermes-data

NEXT_PUBLIC_API_URL=https://ops.themealz.com

# Production QA runner. Set these only in protected production env storage.
QA_BASE_URL=https://ops.themealz.com
QA_API_URL=https://ops.themealz.com
VORYX_QA_ADMIN_EMAIL=qa-admin@example.com
VORYX_QA_ADMIN_PASSWORD=replace-with-protected-qa-admin-password
RETELL_PERMANENT_AGENT_ID=
